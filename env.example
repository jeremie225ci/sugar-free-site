# Client Firebase config (from your Firebase Console → Project settings → General)
NEXT_PUBLIC_FIREBASE_API_KEY=
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=
NEXT_PUBLIC_FIREBASE_PROJECT_ID=
NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET=
NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=
NEXT_PUBLIC_FIREBASE_APP_ID=
# Optional for Analytics
NEXT_PUBLIC_FIREBASE_MEASUREMENT_ID=

# Admin SDK service account (from Firebase Service Accounts JSON)
FIREBASE_PROJECT_ID=
FIREBASE_CLIENT_EMAIL=
# Private key with literal \n newlines escaped as \n
FIREBASE_PRIVATE_KEY=

# Public site URL
NEXT_PUBLIC_SITE_URL=https://www.sugar-frees.com

# Secret used to sign email verification state and hashes
WEB_AUTH_STATE_SECRET=

# Web onboarding glowup proxy
GLOWUP_FUNCTION_URL=

# Resend email verification
RESEND_API_KEY=
RESEND_FROM_EMAIL=

# Lemon Squeezy
LEMONSQUEEZY_API_KEY=
LEMONSQUEEZY_STORE_ID=
LEMONSQUEEZY_VARIANT_ID=
LEMONSQUEEZY_MONTHLY_VARIANT_ID=
LEMONSQUEEZY_YEARLY_VARIANT_ID=
LEMONSQUEEZY_WEBHOOK_SECRET=
LEMONSQUEEZY_TEST_MODE=false
